"""
KRNX Compute - Worker

Background worker that processes compute jobs from the queue.
Handles embedding generation, salience scoring, and cleanup.

Usage:
    # Create components
    queue = JobQueue("jobs.db")
    embeddings = EmbeddingEngine()
    vectors = VectorStore()
    salience = SalienceEngine()
    
    # Create and run worker
    worker = ComputeWorker(
        queue=queue,
        embeddings=embeddings,
        vectors=vectors,
        salience=salience,
    )
    
    # Run (blocking)
    await worker.run()
    
    # Or run in background
    import asyncio
    task = asyncio.create_task(worker.run())
    # ... do other things ...
    worker.stop()
    await task
"""

import asyncio
import logging
import time
import signal
from typing import Optional, Dict, Any, Callable
from dataclasses import dataclass, field

from chillbot.compute.queue import JobQueue, Job, JobType, JobStatus
from chillbot.compute.embeddings import EmbeddingEngine
from chillbot.compute.vectors import VectorStore
from chillbot.compute.salience import SalienceEngine, SalienceMethod

logger = logging.getLogger(__name__)


@dataclass
class WorkerStats:
    """Worker statistics."""
    started_at: float = 0.0
    jobs_processed: int = 0
    jobs_failed: int = 0
    embeddings_generated: int = 0
    vectors_indexed: int = 0
    salience_computed: int = 0
    last_job_at: Optional[float] = None
    
    def to_dict(self) -> Dict[str, Any]:
        """Convert to dictionary."""
        runtime = time.time() - self.started_at if self.started_at else 0
        jobs_per_sec = self.jobs_processed / runtime if runtime > 0 else 0
        
        return {
            "runtime_seconds": round(runtime, 2),
            "jobs_processed": self.jobs_processed,
            "jobs_failed": self.jobs_failed,
            "embeddings_generated": self.embeddings_generated,
            "vectors_indexed": self.vectors_indexed,
            "salience_computed": self.salience_computed,
            "jobs_per_second": round(jobs_per_sec, 3),
            "last_job_at": self.last_job_at,
        }


@dataclass
class WorkerConfig:
    """Worker configuration."""
    batch_size: int = 10                    # Jobs per batch
    poll_interval: float = 1.0              # Seconds between polls when idle
    busy_poll_interval: float = 0.1         # Seconds between polls when busy
    stale_job_timeout: float = 300.0        # Reset jobs running longer than this
    cleanup_interval: float = 3600.0        # Cleanup old jobs every hour
    max_batch_embed: int = 100              # Max texts per batch embedding
    vector_batch_size: int = 50             # Max vectors per batch index


class ComputeWorker:
    """
    Background worker for compute jobs.
    
    Processes jobs from queue:
    - EMBED: Generate embedding, store in vector DB
    - EMBED_BATCH: Batch embedding generation
    - SALIENCE: Compute salience score
    - DELETE_VECTOR: Remove from vector DB
    
    Thread-safe, graceful shutdown, automatic retry.
    """
    
    def __init__(
        self,
        queue: JobQueue,
        embeddings: EmbeddingEngine,
        vectors: VectorStore,
        salience: Optional[SalienceEngine] = None,
        config: Optional[WorkerConfig] = None,
        kernel_client: Optional[Any] = None,  # For fetching events if needed
    ):
        """
        Initialize compute worker.
        
        Args:
            queue: Job queue to process
            embeddings: Embedding engine
            vectors: Vector store
            salience: Salience engine (optional)
            config: Worker configuration
            kernel_client: KRNX client for fetching events (optional)
        """
        self.queue = queue
        self.embeddings = embeddings
        self.vectors = vectors
        self.salience = salience or SalienceEngine()
        self.config = config or WorkerConfig()
        self.kernel = kernel_client
        
        self._running = False
        self._stats = WorkerStats()
        self._last_cleanup = 0.0
        
        # Custom job handlers
        self._handlers: Dict[JobType, Callable] = {}
    
    def register_handler(
        self,
        job_type: JobType,
        handler: Callable,
    ):
        """
        Register custom job handler.
        
        Args:
            job_type: Job type to handle
            handler: Async function(job) -> None
        """
        self._handlers[job_type] = handler
    
    async def run(self):
        """
        Main worker loop. Runs until stopped.
        
        Call stop() or send SIGINT/SIGTERM to stop gracefully.
        """
        self._running = True
        self._stats = WorkerStats(started_at=time.time())
        
        logger.info("[WORKER] Starting compute worker")
        logger.info(f"   Batch size: {self.config.batch_size}")
        logger.info(f"   Poll interval: {self.config.poll_interval}s")
        
        # Setup signal handlers for graceful shutdown
        def handle_signal(sig, frame):
            logger.info(f"[WORKER] Received signal {sig}, stopping...")
            self._running = False
        
        try:
            signal.signal(signal.SIGINT, handle_signal)
            signal.signal(signal.SIGTERM, handle_signal)
        except ValueError:
            # Signals can only be set in main thread
            pass
        
        try:
            while self._running:
                try:
                    # Periodic cleanup
                    await self._maybe_cleanup()
                    
                    # Reset stale jobs
                    stale = self.queue.reset_stale(self.config.stale_job_timeout)
                    if stale > 0:
                        logger.warning(f"[WORKER] Reset {stale} stale jobs")
                    
                    # Dequeue batch
                    jobs = self.queue.dequeue(batch_size=self.config.batch_size)
                    
                    if not jobs:
                        await asyncio.sleep(self.config.poll_interval)
                        continue
                    
                    # Process jobs
                    for job in jobs:
                        await self._process_job(job)
                    
                    # Short sleep between busy batches
                    await asyncio.sleep(self.config.busy_poll_interval)
                    
                except asyncio.CancelledError:
                    logger.info("[WORKER] Cancelled, stopping...")
                    break
                except Exception as e:
                    logger.error(f"[WORKER] Loop error: {e}")
                    self._stats.jobs_failed += 1
                    await asyncio.sleep(self.config.poll_interval)
        
        finally:
            logger.info("[WORKER] Stopped")
            logger.info(f"   Processed: {self._stats.jobs_processed} jobs")
            logger.info(f"   Failed: {self._stats.jobs_failed} jobs")
            logger.info(f"   Embeddings: {self._stats.embeddings_generated}")
    
    async def _process_job(self, job: Job):
        """Process a single job."""
        try:
            logger.debug(f"[WORKER] Processing {job.job_type.value}: {job.job_id}")
            
            # Check for custom handler
            if job.job_type in self._handlers:
                await self._handlers[job.job_type](job)
            elif job.job_type == JobType.EMBED:
                await self._handle_embed(job)
            elif job.job_type == JobType.EMBED_BATCH:
                await self._handle_embed_batch(job)
            elif job.job_type == JobType.SALIENCE:
                await self._handle_salience(job)
            elif job.job_type == JobType.SALIENCE_BATCH:
                await self._handle_salience_batch(job)
            elif job.job_type == JobType.DELETE_VECTOR:
                await self._handle_delete_vector(job)
            elif job.job_type == JobType.CONSOLIDATE:
                await self._handle_consolidate(job)
            elif job.job_type == JobType.CUSTOM:
                await self._handle_custom(job)
            else:
                logger.warning(f"[WORKER] Unknown job type: {job.job_type}")
            
            # Mark complete
            self.queue.complete(job.job_id)
            self._stats.jobs_processed += 1
            self._stats.last_job_at = time.time()
            
        except Exception as e:
            logger.error(f"[WORKER] Job {job.job_id} failed: {e}")
            self.queue.fail(job.job_id, str(e))
            self._stats.jobs_failed += 1
    
    async def _handle_embed(self, job: Job):
        """
        Handle single embedding job.
        
        Payload:
            event_id: str
            text: str
            metadata: dict (optional)
        """
        event_id = job.payload["event_id"]
        text = job.payload.get("text", "")
        metadata = job.payload.get("metadata", {})
        
        if not text:
            logger.debug(f"[WORKER] Skipping empty text for {event_id}")
            return
        
        # Generate embedding
        vector = self.embeddings.embed(text)
        
        # Ensure collection exists
        self.vectors.ensure_collection(job.workspace_id, self.embeddings.dimension)
        
        # Index
        self.vectors.index(
            workspace_id=job.workspace_id,
            id=event_id,
            vector=vector,
            payload={
                "event_id": event_id,
                "text_preview": text[:200],
                "timestamp": time.time(),
                **metadata,
            },
        )
        
        self._stats.embeddings_generated += 1
        self._stats.vectors_indexed += 1
        
        logger.debug(f"[WORKER] Embedded {event_id}")
    
    async def _handle_embed_batch(self, job: Job):
        """
        Handle batch embedding job.
        
        Payload:
            items: list of {event_id, text, metadata}
        """
        items = job.payload.get("items", [])
        
        if not items:
            return
        
        # Extract texts
        texts = [item.get("text", "") for item in items]
        
        # Batch embed
        vectors = self.embeddings.embed_batch(
            texts,
            batch_size=self.config.max_batch_embed,
        )
        
        # Ensure collection
        self.vectors.ensure_collection(job.workspace_id, self.embeddings.dimension)
        
        # Build points for batch index
        points = []
        for item, vector in zip(items, vectors):
            event_id = item["event_id"]
            text = item.get("text", "")
            metadata = item.get("metadata", {})
            
            points.append((
                event_id,
                vector,
                {
                    "event_id": event_id,
                    "text_preview": text[:200],
                    "timestamp": time.time(),
                    **metadata,
                },
            ))
        
        # Batch index
        for i in range(0, len(points), self.config.vector_batch_size):
            batch = points[i:i + self.config.vector_batch_size]
            self.vectors.index_batch(job.workspace_id, batch)
        
        self._stats.embeddings_generated += len(vectors)
        self._stats.vectors_indexed += len(points)
        
        logger.debug(f"[WORKER] Batch embedded {len(items)} items")
    
    async def _handle_salience(self, job: Job):
        """
        Handle salience computation job.
        
        Payload:
            event_id: str
            timestamp: float
            access_count: int (optional)
        """
        event_id = job.payload["event_id"]
        timestamp = job.payload["timestamp"]
        access_count = job.payload.get("access_count", 0)
        
        score = self.salience.compute(
            event_id=event_id,
            timestamp=timestamp,
            access_count=access_count,
            method=SalienceMethod.COMPOSITE,
        )
        
        # Update vector payload with salience score
        # Note: This requires updating the existing vector
        existing = self.vectors.get(job.workspace_id, event_id)
        if existing:
            payload = existing.payload
            payload["salience_score"] = score.score
            payload["salience_computed_at"] = score.computed_at
            
            # Re-index with updated payload (vector stays same)
            # We'd need the vector to do this - skip for now
            # TODO: Implement salience storage strategy
        
        self._stats.salience_computed += 1
        
        logger.debug(f"[WORKER] Salience for {event_id}: {score.score:.3f}")
    
    async def _handle_salience_batch(self, job: Job):
        """
        Handle batch salience computation.
        
        Payload:
            items: list of {event_id, timestamp, access_count}
        """
        items = job.payload.get("items", [])
        
        if not items:
            return
        
        scores = self.salience.compute_batch(items)
        self._stats.salience_computed += len(scores)
        
        logger.debug(f"[WORKER] Batch salience for {len(items)} items")
    
    async def _handle_delete_vector(self, job: Job):
        """
        Handle vector deletion job.
        
        Payload:
            event_id: str (or)
            event_ids: list of str
        """
        event_id = job.payload.get("event_id")
        event_ids = job.payload.get("event_ids", [])
        
        if event_id:
            self.vectors.delete(job.workspace_id, event_id)
            logger.debug(f"[WORKER] Deleted vector {event_id}")
        
        if event_ids:
            self.vectors.delete_batch(job.workspace_id, event_ids)
            logger.debug(f"[WORKER] Deleted {len(event_ids)} vectors")
    
    async def _handle_consolidate(self, job: Job):
        """
        Handle memory consolidation job.
        
        Payload:
            strategy: str
            params: dict
        """
        # TODO: Implement consolidation strategies
        # - Summarization
        # - Clustering
        # - Importance-based pruning
        logger.debug(f"[WORKER] Consolidation not yet implemented")
    
    async def _handle_custom(self, job: Job):
        """
        Handle custom job.
        
        Payload:
            handler: str (handler name)
            data: dict
        """
        handler_name = job.payload.get("handler")
        
        if handler_name:
            logger.warning(f"[WORKER] Custom handler '{handler_name}' not registered")
        else:
            logger.debug(f"[WORKER] Custom job with no handler specified")
    
    async def _maybe_cleanup(self):
        """Periodic cleanup of old jobs."""
        now = time.time()
        
        if now - self._last_cleanup < self.config.cleanup_interval:
            return
        
        self._last_cleanup = now
        
        deleted = self.queue.cleanup()
        if deleted > 0:
            logger.info(f"[WORKER] Cleaned up {deleted} old jobs")
    
    def stop(self):
        """Stop the worker gracefully."""
        logger.info("[WORKER] Stop requested")
        self._running = False
    
    @property
    def is_running(self) -> bool:
        """Check if worker is running."""
        return self._running
    
    @property
    def stats(self) -> WorkerStats:
        """Get worker statistics."""
        return self._stats
    
    def get_stats_dict(self) -> Dict[str, Any]:
        """Get statistics as dictionary."""
        stats = self._stats.to_dict()
        stats["queue_pending"] = self.queue.pending_count()
        stats["queue_running"] = self.queue.running_count()
        return stats


async def run_worker(
    db_path: str = "compute_jobs.db",
    qdrant_url: str = "http://localhost:6333",
    model_name: str = "all-MiniLM-L6-v2",
):
    """
    Convenience function to run a worker with default configuration.
    
    Args:
        db_path: Path to job queue database
        qdrant_url: Qdrant server URL
        model_name: Embedding model name
    """
    queue = JobQueue(db_path)
    embeddings = EmbeddingEngine(model_name)
    vectors = VectorStore(url=qdrant_url)
    salience = SalienceEngine()
    
    worker = ComputeWorker(
        queue=queue,
        embeddings=embeddings,
        vectors=vectors,
        salience=salience,
    )
    
    try:
        await worker.run()
    finally:
        queue.close()
        vectors.close()


if __name__ == "__main__":
    # Allow running directly: python -m compute.worker
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s - %(name)s - %(levelname)s - %(message)s",
    )
    
    asyncio.run(run_worker())
