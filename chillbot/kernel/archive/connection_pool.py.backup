"""
KRNX Connection Pool - Global Redis Connection Management

Provides singleton connection pool for efficient Redis connection sharing.

Benefits:
- Reduced connection overhead (reuse connections)
- Thread-safe singleton pattern
- Configurable connection limits
- Automatic connection management

Usage:
    from chillbot.kernel.connection_pool import configure_pool, get_redis_client, close_pool
    
    # At application startup
    configure_pool(host="localhost", port=6379, max_connections=50)
    
    # Get Redis client anywhere in app
    redis_client = get_redis_client()
    
    # At shutdown
    close_pool()
"""

import redis
import os
import threading
import logging
from typing import Optional, Dict, Any

logger = logging.getLogger(__name__)


# ==============================================
# CONNECTION POOL (Singleton)
# ==============================================

class ConnectionPool:
    """
    Global Redis connection pool (singleton).
    
    Ensures all Redis clients share the same connection pool,
    reducing overhead and enabling better resource management.
    
    Thread-safe using double-checked locking pattern.
    """
    _instance: Optional['ConnectionPool'] = None
    _lock = threading.Lock()
    
    def __new__(cls):
        if cls._instance is None:
            with cls._lock:
                if cls._instance is None:
                    cls._instance = super().__new__(cls)
                    cls._instance._initialized = False
        return cls._instance
    
    def __init__(self):
        if self._initialized:
            return
        self._pool: Optional[redis.ConnectionPool] = None
        self._config: Dict[str, Any] = {}
        self._initialized = True
    
    def configure(
        self,
        host: Optional[str] = None,
        port: Optional[int] = None,
        password: Optional[str] = None,
        max_connections: int = 50,
        decode_responses: bool = True
    ):
        """
        Configure connection pool (called once at startup).
        
        Args:
            host: Redis host
            port: Redis port
            password: Optional password
            max_connections: Maximum connections in pool
            decode_responses: Auto-decode responses to strings
        """
        if self._pool is not None:
            logger.warning("[WARN] Connection pool already configured, ignoring")
            return
        
        # Use environment variables as fallback
        host = host or os.getenv("REDIS_HOST", "localhost")
        port = port or int(os.getenv("REDIS_PORT", "6379"))
        
        self._config = {
            'host': host,
            'port': port,
            'password': password,
            'max_connections': max_connections,
            'decode_responses': decode_responses
        }
        
        self._pool = redis.ConnectionPool(**self._config)
        logger.info(f"[OK] Connection pool configured: {host}:{port} (max={max_connections})")
    
    def get_pool(self) -> redis.ConnectionPool:
        """
        Get underlying connection pool.
        
        Returns:
            redis.ConnectionPool instance
        
        Raises:
            RuntimeError: If pool not configured
        """
        if self._pool is None:
            raise RuntimeError(
                "ConnectionPool not configured. "
                "Call configure_pool() before using Redis clients."
            )
        return self._pool
    
    def get_redis_client(self) -> redis.Redis:
        """
        Get Redis client using shared pool.
        
        Returns:
            redis.Redis client instance
        """
        return redis.Redis(connection_pool=self.get_pool())
    
    def close(self):
        """Close connection pool and disconnect all connections."""
        if self._pool is not None:
            self._pool.disconnect()
            self._pool = None
            logger.info("[OK] Connection pool closed")


# ==============================================
# GLOBAL SINGLETON INSTANCE
# ==============================================

_connection_pool = ConnectionPool()


# ==============================================
# PUBLIC API (Convenience Functions)
# ==============================================

def configure_pool(
    host: str = "localhost",
    port: int = 6379,
    password: Optional[str] = None,
    max_connections: int = 50,
    decode_responses: bool = True
):
    """
    Configure global connection pool.
    
    Should be called once at application startup.
    
    Args:
        host: Redis host
        port: Redis port
        password: Optional password
        max_connections: Maximum connections in pool
        decode_responses: Auto-decode responses to strings
    
    Example:
        configure_pool(host="localhost", port=6379, max_connections=100)
    """
    _connection_pool.configure(
        host=host,
        port=port,
        password=password,
        max_connections=max_connections,
        decode_responses=decode_responses
    )


def get_pool() -> redis.ConnectionPool:
    """
    Get global connection pool.
    
    Returns:
        redis.ConnectionPool instance
    
    Raises:
        RuntimeError: If pool not configured
    """
    return _connection_pool.get_pool()


def get_redis_client() -> redis.Redis:
    """
    Get Redis client using global connection pool.
    
    Returns:
        redis.Redis client
    
    Example:
        redis_client = get_redis_client()
        redis_client.set('key', 'value')
    """
    return _connection_pool.get_redis_client()


def close_pool():
    """
    Close global connection pool.
    
    Should be called at application shutdown.
    """
    _connection_pool.close()


# ==============================================
# EXPORTS
# ==============================================

__all__ = [
    'configure_pool',
    'get_pool',
    'get_redis_client',
    'close_pool',
    'ConnectionPool'
]
